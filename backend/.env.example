# ---------------------------------------------------------------------------
# GDMS Space Hardware Assistant — Backend Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.
# ---------------------------------------------------------------------------

# Your enterprise AI gateway API key (or OpenAI key for local dev)
INTERNAL_API_KEY=your-api-key-here

# Base URL of the OpenAI-compatible endpoint.
# For direct OpenAI: https://api.openai.com/v1
# For an internal enterprise gateway: https://ai-gateway.your-corp.com/v1
INTERNAL_BASE_URL=https://api.openai.com/v1

# Model name as recognized by the endpoint (e.g. gpt-4o, gpt-4o-mini, claude-3-5-sonnet)
INTERNAL_MODEL_NAME=gpt-4o-mini
